---
// KiwiHacks Beacons Landing Page

let tiers = [];
const ATTIO_API_KEY = import.meta.env.ATTIO_API_KEY;

if (ATTIO_API_KEY) {
    try {
        const response = await fetch('https://api.attio.com/v2/objects/referral_tier/records', {
            headers: {
                'Authorization': `Bearer ${ATTIO_API_KEY}`,
                'Accept': 'application/json'
            }
        });
        if (response.ok) {
            const data = await response.json();
            tiers = data.data.map((record) => {
                const getVal = (attr) => record.values[attr]?.[0]?.value;
                return {
                    name: getVal('name') || 'Unnamed Tier',
                    icon: getVal('icon') || '⭐️',
                    requirement: getVal('requirement') || '0 Referrals',
                    benefits: getVal('benefits')?.split('\n').filter(Boolean) || [],
                    isFeatured: getVal('is_featured') || false,
                    order: getVal('order') || 0
                };
            }).sort((a, b) => a.order - b.order);
        } else {
            console.error("Failed to fetch from Attio:", await response.text());
        }
    } catch (error) {
        console.error("Error fetching from Attio:", error);
    }
}

if (!tiers || tiers.length === 0) {
    tiers = [
        {
            name: 'Seedling',
            icon: '🌱',
            requirement: '1-5 Referrals',
            benefits: ['[Benefit 1]', '[Benefit 2]'],
            isFeatured: false
        },
        {
            name: 'Pathfinder',
            icon: '🌿',
            requirement: '6-15 Referrals',
            benefits: ['[Benefit 1]', '[Benefit 2]', '[Benefit 3]'],
            isFeatured: true
        },
        {
            name: 'Beacon',
            icon: '🌳',
            requirement: '16+ Referrals',
            benefits: ['[Benefit 1]', '[Benefit 2]', '[Benefit 3]'],
            isFeatured: false
        }
    ];
}
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <title>KiwiHacks Beacons | Referral Program</title>
        <meta name="description" content="Join the KiwiHacks Beacons referral program. Refer friends and earn exclusive tier rewards." />
    </head>
    <body>
        <img class="logo" src="/images/kiwihackslogo.png" alt="KiwiHacks Kiwi Bird" draggable="false" />

        <main>
            <header id="home">


                <img src="/images/kiwihackstext.png" alt="KiwiHacks" class="kiwihacks-text" draggable="false" />
                <h1 class="display beacons-title">Beacons</h1>
                <h2 class="mono subtitle">New Zealand's high school hackathon referral program</h2>

                <div class="button-container">
                    <a class="sign-up-link big-button" href="#signup">
                        <b>Join the Beacons Program</b>
                    </a>
                </div>
            </header>

            <section class="tiers-section">
                <h2 class="display">Referral Tiers</h2>
                <p>Climb the ranks and claim your rewards.</p>

                <div class="tiers-grid">
                    {tiers.map((tier) => (
                        <div class={`tier-card ${tier.isFeatured ? 'featured' : ''}`}>
                            <div class="tier-icon">{tier.icon}</div>
                            <h3 class="display">{tier.name}</h3>
                            <div class="tier-req mono">{tier.requirement}</div>
                            <ul class="tier-benefits">
                                {tier.benefits.map((benefit) => (
                                    <li>{benefit}</li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>
            </section>
        </main>
    </body>
</html>

<style is:global>
    @font-face {
        font-family: 'Figtree';
        src: url("/fonts/Figtree.ttf") format("truetype");
        font-display: swap;
    }

    @font-face {
        font-family: 'ABeeZee';
        src: url("/fonts/ABeeZee.ttf") format("truetype");
        font-display: swap;
    }

    @font-face {
        font-family: 'Source Code Pro';
        src: url("/fonts/SourceCodePro.ttf") format("truetype");
        font-display: swap;
    }

    /* === Exact kiwihacks-site variables === */
    :root {
        --bright-blue: #36c6fb;
        --light-blue: #91e2ffce;
        --very-light-blue: #baedff;
        --very-dark-green: #132f1e;
        --dark-green: #2e522b;
        --medium-green: #76b070;
        --semi-opaque-green: #64d6ff4d;
        --medium-light-green: #76b07080;
    }

    /* === Exact kiwihacks-site index.css === */
    html {
        scroll-behavior: smooth;
        line-height: 1.5;
        font-weight: 400;
        background: #eae6e2;
        font-synthesis: none;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-align: center;
        font-family: "Figtree", sans-serif;
        color: #132f1e;
    }

    html, body {
        max-width: 100vw;
        overflow-x: hidden;
        margin: 0;
        padding: 0;
        scrollbar-width: thin;
        scrollbar-color: #76b070 #eae6e2;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    ::-webkit-scrollbar { width: 12px; }
    ::-webkit-scrollbar-track { background: #eae6e2; }
    ::-webkit-scrollbar-thumb { background: #76b070; border-radius: 6px; border: 2px solid #eae6e2; }
    ::-webkit-scrollbar-thumb:hover { background: #598654; }

    /* === Exact kiwihacks-site App.css === */
    .display { font-family: "ABeeZee", sans-serif; }
    .mono { font-family: "Source Code Pro", monospace; }

    .logo {
        width: 25%;
        height: auto;
        margin-bottom: 0;
        -webkit-user-drag: none;
        user-select: none;
    }

    .button-container {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        margin-bottom: 3rem;
        flex-wrap: wrap;
    }

    .sign-up-link {
        border-radius: 15px;
        color: var(--very-dark-green);
        text-decoration: none;
    }

    .big-button {
        padding: 1rem;
        padding-left: 4rem;
        padding-right: 4rem;
        background: var(--medium-green);
        border: 1.5px dashed var(--very-dark-green);
    }

    .big-button:hover {
        background: #88bc82;
        box-shadow: 0 8px 6px rgba(0, 0, 0, 0.2);
    }

    p {
        text-align: left;
        margin: auto;
        width: 50%;
        padding: 1rem;
    }

    /* === Exact kiwihacks-site Hero.css === */
    #home {
        position: relative;
        padding-bottom: 2rem;
        min-height: 420px;
    }

    .kiwihacks-text {
        width: 30%;
        margin-top: 0;
        -webkit-user-drag: none;
        user-select: none;
    }

    .beacons-title {
        color: var(--dark-green);
        font-size: 6rem;
        font-weight: 400;
        line-height: normal;
        letter-spacing: 0.2rem;
        margin: 0;
        padding: 0;
        transition: 0.4s ease;
    }

    .beacons-title:hover {
        transform: scale(1.05);
    }

    .subtitle {
        font-weight: 400;
        color: #132f1e;
        margin: 0;
        padding: 0 1.5rem;
        margin-bottom: 1rem;
        position: relative;
        z-index: 10;
    }



    /* === Tiers section === */
    .tiers-section {
        padding-top: 0;
    }
    main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem 4rem;
    }

    .tiers-section h2 {
        color: var(--dark-green);
        font-size: 3rem;
        font-weight: 400;
        letter-spacing: 0.1rem;
        margin-bottom: 0;
    }

    .tiers-section > p {
        text-align: center;
        width: auto;
        margin-bottom: 2rem;
    }

    .tiers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.5rem;
        align-items: start;
        text-align: left;
    }

    .tier-card {
        background: rgba(255, 255, 255, 0.5);
        border: 1.5px dashed var(--very-dark-green);
        border-radius: 15px;
        padding: 1.5rem;
    }

    .tier-card.featured {
        background: rgba(118, 176, 112, 0.15);
        border-color: var(--dark-green);
    }

    .tier-icon {
        font-size: 2rem;
        margin-bottom: 0.25rem;
    }

    .tier-card h3 {
        color: var(--dark-green);
        font-size: 1.6rem;
        font-weight: 400;
        letter-spacing: 0.05rem;
        margin: 0 0 0.15rem 0;
    }

    .tier-req {
        color: var(--dark-green);
        font-size: 0.8rem;
        display: block;
        margin-bottom: 1rem;
    }

    .tier-benefits {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .tier-benefits li {
        padding: 0.25rem 0 0.25rem 1.25rem;
        position: relative;
        color: var(--very-dark-green);
        text-align: left;
        width: auto;
        font-size: 0.95rem;
    }

    .tier-benefits li::before {
        content: '–';
        position: absolute;
        left: 0;
        color: var(--medium-green);
    }

    /* === Exact kiwihacks-site mobile === */
    @media screen and (max-width: 768px) {
        html { font-size: 14px; }

        body { overflow-x: hidden; }

        *, *::before, *::after {
            transition: none !important;
            animation: none !important;
            transform: none !important;
            translate: none !important;
            scale: none !important;
            rotate: none !important;
        }

        .beacons-title:hover, .big-button:hover {
            transform: none !important;
            translate: none !important;
            scale: none !important;
            box-shadow: none !important;
        }

        p, .tiers-section > p { width: 90% !important; }

        .logo { width: 50%; }

        .kiwihacks-text { width: 80%; }

        .beacons-title { font-size: 3rem; }

        .big-button {
            width: 80%;
            padding: 1rem;
            display: block;
            margin: 2rem auto;
        }

        .stars { display: none; }
    }

    @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
            transition: none !important;
            animation: none !important;
            scale: none !important;
        }
        .beacons-title:hover, .big-button:hover {
            transform: none !important;
            scale: none !important;
        }
    }
</style>
