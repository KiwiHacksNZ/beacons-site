---
// KiwiHacks Beacons Landing Page

const AIRTABLE_TOKEN = import.meta.env.AIRTABLE_TOKEN;
const AIRTABLE_BASE_ID = import.meta.env.AIRTABLE_BASE_ID;
const AIRTABLE_TABLE = import.meta.env.AIRTABLE_TABLE ?? 'Tiers';

let tiers = [];

if (AIRTABLE_TOKEN && AIRTABLE_BASE_ID) {
    try {
        const url = `https://api.airtable.com/v0/${AIRTABLE_BASE_ID}/${encodeURIComponent(AIRTABLE_TABLE)}?sort[0][field]=Order&sort[0][direction]=asc`;
        const res = await fetch(url, {
            headers: { 'Authorization': `Bearer ${AIRTABLE_TOKEN}` }
        });
        if (res.ok) {
            const data = await res.json();
            tiers = data.records.map((r) => ({
                name: r.fields['Name'] ?? 'Unnamed Tier',
                icon: r.fields['Icon'] ?? '⭐️',
                requirement: r.fields['Requirement'] ?? '0 Referrals',
                benefits: (r.fields['Benefits'] ?? '').split('\n').filter(Boolean),
                isFeatured: r.fields['Featured'] ?? false,
            }));
        } else {
            console.error('Airtable fetch failed:', await res.text());
        }
    } catch (e) {
        console.error('Airtable error:', e);
    }
}

// Fallback if not configured yet
if (tiers.length === 0) {
    tiers = [
        {
            name: 'Seedling',
            icon: '🌱',
            requirement: '1-5 Referrals',
            benefits: ['[Benefit 1]', '[Benefit 2]'],
            isFeatured: false
        },
        {
            name: 'Pathfinder',
            icon: '🌿',
            requirement: '6-15 Referrals',
            benefits: ['[Benefit 1]', '[Benefit 2]', '[Benefit 3]'],
            isFeatured: true
        },
        {
            name: 'Beacon',
            icon: '🌳',
            requirement: '16+ Referrals',
            benefits: ['[Benefit 1]', '[Benefit 2]', '[Benefit 3]'],
            isFeatured: false
        }
    ];
}
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <title>KiwiHacks Beacons | Referral Program</title>
        <meta name="description" content="Join the KiwiHacks Beacons referral program. Refer friends and earn exclusive tier rewards." />
    </head>
    <body>
        <img class="logo" src="/images/kiwihackslogo.png" alt="KiwiHacks Kiwi Bird" draggable="false" />

        <main>
            <header id="home">


                <img src="/images/kiwihackstext.png" alt="KiwiHacks" class="kiwihacks-text" draggable="false" />
                <h1 class="display beacons-title">Beacons</h1>
                <h2 class="mono subtitle">New Zealand's high school hackathon referral program</h2>

                <div class="button-container">
                    <a class="sign-up-link big-button" href="https://kiwihacks.fillout.com/beacons" target="_blank">
                        <b>Join the Beacons Program</b>
                    </a>
                </div>
            </header>

            <section class="tiers-section">
                <h2 class="display">Referral Tiers</h2>
                <p>Climb the ranks and claim your rewards.</p>

                <div class="tiers-grid">
                    {tiers.map((tier) => (
                        <div class={`tier-card ${tier.isFeatured ? 'featured' : ''}`}>
                            <h3 class="display">{tier.name}</h3>
                            <div class="tier-req mono">{tier.requirement}</div>
                            <ul class="tier-benefits">
                                {tier.benefits.map((benefit) => (
                                    <li>{benefit}</li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>
            </section>

            <section id="extended-desc">
              <h2>About Beacons</h2>
              <p>
              Beacons is KiwiHacks' referral program. You get your friends to sign up and show up to a KiwiHacks event, we'll reward you!
              Check out the tiers above to see the cool prizes!
              </p>
              <p>
              When you sign up, we'll send you a unique referral code + link! Get your friends to sign up with that link and we'll send you cool stuff!
              </p>
            </section>
        </main>

        <footer>
            <div class="footer-signature-container">
                <picture>
                    <source srcset="/images/signatures-wide.png" media="(min-width: 768px)" />
                    <img
                        src="/images/signatures.png"
                        alt="Signatures of the KiwiHacks team"
                        class="signatures"
                        draggable="false"
                    />
                </picture>
            </div>
            <div class="footer-text">
                <p class="footer-text-piece">© 2026 KiwiHacks</p>
                <p class="footer-text-piece">Built with ❤️ by teens, for teens.</p>
                <p class="footer-text-piece">
                    <a href="https://github.com/KiwiHacksNZ/beacons-site" target="_blank" rel="noreferrer">View our code on GitHub</a>
                </p>
            </div>
            <div class="footer-links">
                <a href="https://discord.gg/SNdNUQ4Vp7" target="_blank" class="footer-link" aria-label="Discord">
                    <!-- Discord icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 512"><path fill="currentColor" d="M524.531 69.836a1.5 1.5 0 0 0-.764-.7A485.065 485.065 0 0 0 404.081 32.03a1.816 1.816 0 0 0-1.923.91 337.461 337.461 0 0 0-14.9 30.6 447.848 447.848 0 0 0-134.426 0 309.541 309.541 0 0 0-15.135-30.6 1.89 1.89 0 0 0-1.924-.91 483.689 483.689 0 0 0-119.688 37.107 1.712 1.712 0 0 0-.788.676C39.068 183.651 18.186 294.69 28.43 404.354a2.016 2.016 0 0 0 .765 1.375 487.666 487.666 0 0 0 146.825 74.189 1.9 1.9 0 0 0 2.063-.676A348.2 348.2 0 0 0 208.12 430.4a1.86 1.86 0 0 0-1.019-2.588 321.173 321.173 0 0 1-45.868-21.853 1.885 1.885 0 0 1-.185-3.126c3.082-2.309 6.166-4.711 9.109-7.137a1.819 1.819 0 0 1 1.9-.256c96.229 43.917 200.41 43.917 295.5 0a1.812 1.812 0 0 1 1.924.233c2.944 2.426 6.027 4.851 9.132 7.16a1.884 1.884 0 0 1-.162 3.126 301.407 301.407 0 0 1-45.89 21.83 1.875 1.875 0 0 0-1 2.611 391.055 391.055 0 0 0 30.014 48.815 1.864 1.864 0 0 0 2.063.7A486.048 486.048 0 0 0 610.7 405.729a1.882 1.882 0 0 0 .765-1.352c12.264-126.783-20.532-236.912-86.934-334.541zM222.491 337.58c-28.972 0-52.844-26.587-52.844-59.239s23.409-59.241 52.844-59.241c29.665 0 53.306 26.82 52.843 59.239 0 32.654-23.41 59.241-52.843 59.241zm195.38 0c-28.971 0-52.843-26.587-52.843-59.239s23.409-59.241 52.843-59.241c29.667 0 53.307 26.82 52.844 59.239 0 32.654-23.176 59.241-52.844 59.241z"/></svg>
                </a>
                <a href="https://www.instagram.com/kiwihacks/" target="_blank" class="footer-link" aria-label="Instagram">
                    <!-- Instagram icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512"><path fill="currentColor" d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/></svg>
                </a>
                <a href="https://nz.linkedin.com/company/kiwihacks" target="_blank" class="footer-link" aria-label="LinkedIn">
                    <!-- LinkedIn icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512"><path fill="currentColor" d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z"/></svg>
                </a>
                <a href="https://github.com/orgs/KiwiHacksNZ" target="_blank" class="footer-link" aria-label="GitHub">
                    <!-- GitHub icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 496 512"><path fill="currentColor" d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3.3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3zm44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9.3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8zM97.2 352.9c-1.3 1-1 3.3.7 5.2 1.6 1.6 3.9 2.3 5.2 1 1.3-1 1-3.3-.7-5.2-1.6-1.6-3.9-2.3-5.2-1zm-10.8-8.1c-.7 1.3.3 2.9 2.3 3.9 1.6 1 3.6.7 4.3-.7.7-1.3-.3-2.9-2.3-3.9-2-.6-3.6-.3-4.3.7zm32.4 35.6c-1.6 1.3-1 4.3 1.3 6.2 2.3 2.3 5.2 2.6 6.5 1 1.3-1.3.7-4.3-1.3-6.2-2.2-2.3-5.2-2.6-6.5-1zm-11.4-14.7c-1.6 1-1.6 3.6 0 5.9 1.6 2.3 4.3 3.3 5.6 2.3 1.6-1.3 1.6-3.9 0-6.2-1.4-2.3-4-3.3-5.6-2z"/></svg>
                </a>
            </div>
            <div class="footer-important-links">
                <p>Important Links</p>
                <a href="https://kiwihacks.org/code-of-conduct">Code of Conduct</a>
            </div>
        </footer>
    </body>
</html>

<style is:global>
    @font-face {
        font-family: 'Figtree';
        src: url("/fonts/Figtree.ttf") format("truetype");
        font-display: swap;
    }

    @font-face {
        font-family: 'ABeeZee';
        src: url("/fonts/ABeeZee.ttf") format("truetype");
        font-display: swap;
    }

    @font-face {
        font-family: 'Source Code Pro';
        src: url("/fonts/SourceCodePro.ttf") format("truetype");
        font-display: swap;
    }

    /* === Exact kiwihacks-site variables === */
    :root {
        --bright-blue: #36c6fb;
        --light-blue: #91e2ffce;
        --very-light-blue: #baedff;
        --very-dark-green: #132f1e;
        --dark-green: #2e522b;
        --medium-green: #76b070;
        --semi-opaque-green: #64d6ff4d;
        --medium-light-green: #76b07080;
    }

    /* === Exact kiwihacks-site index.css === */
    html {
        scroll-behavior: smooth;
        line-height: 1.5;
        font-weight: 400;
        background: #eae6e2;
        font-synthesis: none;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-align: center;
        font-family: "Figtree", sans-serif;
        color: #132f1e;
    }

    html, body {
        max-width: 100vw;
        overflow-x: hidden;
        margin: 0;
        padding: 0;
        scrollbar-width: thin;
        scrollbar-color: #76b070 #eae6e2;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    ::-webkit-scrollbar { width: 12px; }
    ::-webkit-scrollbar-track { background: #eae6e2; }
    ::-webkit-scrollbar-thumb { background: #76b070; border-radius: 6px; border: 2px solid #eae6e2; }
    ::-webkit-scrollbar-thumb:hover { background: #598654; }

    /* === Exact kiwihacks-site App.css === */
    .display { font-family: "ABeeZee", sans-serif; }
    .mono { font-family: "Source Code Pro", monospace; }

    .logo {
        width: 25%;
        height: auto;
        margin-bottom: 0;
        -webkit-user-drag: none;
        user-select: none;
    }

    .button-container {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        margin-bottom: 3rem;
        flex-wrap: wrap;
    }

    .sign-up-link {
        border-radius: 15px;
        color: var(--very-dark-green);
        text-decoration: none;
    }

    .big-button {
        padding: 1rem;
        padding-left: 4rem;
        padding-right: 4rem;
        background: var(--medium-green);
        border: 1.5px dashed var(--very-dark-green);
    }

    .big-button:hover {
        background: #88bc82;
        box-shadow: 0 8px 6px rgba(0, 0, 0, 0.2);
    }

    p {
        text-align: left;
        margin: auto;
        width: 50%;
        padding: 1rem;
    }

    /* === Exact kiwihacks-site Hero.css === */
    #home {
        position: relative;
        padding-bottom: 2rem;
        min-height: 420px;
    }

    .kiwihacks-text {
        width: 30%;
        margin-top: 0;
        -webkit-user-drag: none;
        user-select: none;
    }

    .beacons-title {
        color: var(--dark-green);
        font-size: 6rem;
        font-weight: 400;
        line-height: normal;
        letter-spacing: 0.2rem;
        margin: 0;
        padding: 0;
        transition: 0.4s ease;
    }

    .beacons-title:hover {
        transform: scale(1.05);
    }

    .subtitle {
        font-weight: 400;
        color: #132f1e;
        margin: 0;
        padding: 0 1.5rem;
        margin-bottom: 1rem;
        position: relative;
        z-index: 10;
    }



    /* === Tiers section === */
    .tiers-section {
        background-color: #76b07026;
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
        padding: 4rem calc(50vw - 50%) 4rem;
        padding-left: max(2rem, calc(50vw - 580px));
        padding-right: max(2rem, calc(50vw - 580px));
    }
    main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem 4rem;
    }

    .tiers-section h2 {
        color: var(--dark-green);
        font-size: 3rem;
        font-weight: 400;
        letter-spacing: 0.1rem;
        margin-bottom: 0;
    }

    .tiers-section > p {
        text-align: center;
        width: auto;
        margin-bottom: 2rem;
    }

    .tiers-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 1.5rem;
        align-items: stretch;
        text-align: left;
    }

    .tiers-grid .tier-card:nth-child(1) { grid-column: 1 / 3; }
    .tiers-grid .tier-card:nth-child(2) { grid-column: 3 / 5; }
    .tiers-grid .tier-card:nth-child(3) { grid-column: 5 / 7; }
    .tiers-grid .tier-card:nth-child(4) { grid-column: 2 / 4; }
    .tiers-grid .tier-card:nth-child(5) { grid-column: 4 / 6; }

    .tier-card {
        background: rgba(255, 255, 255, 0.5);
        border: 1.5px dashed var(--very-dark-green);
        border-radius: 15px;
        padding: 1.5rem;
    }

    .tier-card.featured {
        background: rgba(118, 176, 112, 0.15);
        border-color: var(--dark-green);
    }

    .tier-icon {
        font-size: 2rem;
        margin-bottom: 0.25rem;
    }

    .tier-card h3 {
        color: var(--dark-green);
        font-size: 1.6rem;
        font-weight: 400;
        letter-spacing: 0.05rem;
        margin: 0 0 0.15rem 0;
    }

    .tier-req {
        color: var(--dark-green);
        font-size: 0.8rem;
        display: block;
        margin-bottom: 1rem;
    }

    .tier-benefits {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .tier-benefits li {
        padding: 0.25rem 0 0.25rem 1.25rem;
        position: relative;
        color: var(--very-dark-green);
        text-align: left;
        width: auto;
        font-size: 0.95rem;
    }

    .tier-benefits li::before {
        content: '–';
        position: absolute;
        left: 0;
        color: var(--medium-green);
    }

    /* === Footer === */
    footer {
        color: #132f1e;
        background-color: #76b07026;
        padding: 2rem;
        display: flex;
        gap: 2rem;
        justify-content: center;
        align-items: center;
        flex-wrap: wrap;
        text-align: center;
    }

    .footer-text-piece {
        padding: 0.2rem;
        width: fit-content;
        font-size: 1.2rem;
    }

    .footer-text-piece a {
        color: inherit;
        text-decoration: underline;
        transition: all 0.3s ease;
    }

    .footer-text-piece a:hover {
        color: var(--bright-blue);
    }

    .footer-signature-container {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 0.5rem;
    }

    .signatures {
        width: 100%;
        max-width: 700px;
        min-width: 200px;
        height: auto;
        border: 5px solid var(--medium-green);
        box-shadow: var(--very-dark-green) 0px 1px 2px 0px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        -webkit-user-drag: none;
        user-select: none;
        display: block;
        margin: 0 auto;
    }

    .signatures:hover {
        box-shadow: var(--very-dark-green) 0px 4px 8px 0px;
        transform: scale(1.01);
    }

    .footer-links {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
        justify-content: center;
        width: 100%;
        margin-top: 1rem;
    }

    .footer-link {
        color: #132f1e;
        text-decoration: none;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .footer-link:hover {
        color: #36c6fb;
        transform: translateY(-3px);
    }

    .footer-link svg {
        width: 32px;
        height: 32px;
    }

    .footer-important-links {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        justify-content: center;
        width: 100%;
        margin-top: 0.5rem;
    }

    .footer-important-links p {
        width: 100%;
        text-align: center;
        font-weight: bold;
        margin: 0;
        font-size: 1.1rem;
    }

    .footer-important-links a {
        color: inherit;
        text-decoration: underline;
        transition: all 0.3s ease;
    }

    .footer-important-links a:hover {
        color: var(--bright-blue);
    }

    /* === Exact kiwihacks-site mobile === */
    @media screen and (max-width: 768px) {
        html { font-size: 14px; }

        body { overflow-x: hidden; }

        *, *::before, *::after {
            transition: none !important;
            animation: none !important;
            transform: none !important;
            translate: none !important;
            scale: none !important;
            rotate: none !important;
        }

        .beacons-title:hover, .big-button:hover {
            transform: none !important;
            translate: none !important;
            scale: none !important;
            box-shadow: none !important;
        }

        p, .tiers-section > p { width: 90% !important; }

        .logo { width: 50%; }

        .kiwihacks-text { width: 80%; }

        .beacons-title { font-size: 3rem; }

        .big-button {
            width: 80%;
            padding: 1rem;
            display: block;
            margin: 2rem auto;
        }

        .tiers-grid {
            grid-template-columns: 1fr !important;
        }

        .tiers-grid .tier-card:nth-child(n) {
            grid-column: 1 / -1 !important;
        }

        .stars { display: none; }

        footer {
            flex-direction: column;
            gap: 1.5rem;
        }

        .footer-signature-container {
